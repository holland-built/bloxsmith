# Alert suppression state — runtime data, not a secret, never committed
backend/data/alert_state.json
backend/data/alert_state.json.tmp

# Audit log — runtime data (hash-chained, tamper-evident), never committed
backend/data/audit_log.jsonl

# Same runtime state, at the paths THIS app actually writes. server.py puts them
# in _STATE_DIR = dirname(VAULT_FILE): under Docker that's the /vault volume, but
# running server.py directly for local dev resolves it to the REPO ROOT — where
# the backend/data/ rules above don't match and `git add -A` would sweep them in.
# audit_log.jsonl carries actor identities and request paths; never commit it.
/audit_log.jsonl
/alert_state.json
/alert_state.json.tmp
/first_seen.json
/first_seen.json.tmp

# encrypted vault — never commit
vault.json
scripts/out_*.json
scripts/out_*.txt
scripts/catalog_*.py
# ...but the nightly MCP drift-check workflow needs these two tracked: the tool
# catalog script it runs, and the baseline snapshot it diffs against.
!scripts/catalog_tools.py
!scripts/out_tools.json
scripts/test_queries.py
scripts/test_workarounds.py
scripts/test_resource_read.py
scripts/test_final.py

mockups/
.mockups/

# saved-view runtime store (VAULT_DIR)
views/

# Third-party demo templates — fetched at build (scripts/fetch_templates.py), never published (ccmarris/uddi_automation_toolkit)
templates/

